{
  "name": "@upgpt/vision-test-harness",
  "version": "0.3.0",
  "license": "MIT",
  "description": "AI-powered visual testing for Chrome extensions, WordPress plugins, and web apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vision-test-harness": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/screenshots",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "visual-testing",
    "visual-regression",
    "playwright",
    "screenshot",
    "ai-testing",
    "mcp",
    "chrome-extension",
    "wordpress",
    "pixel-diff",
    "test-automation",
    "upgpt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UpGPT-ai/vision-test-harness.git"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
